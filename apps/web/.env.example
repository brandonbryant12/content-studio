# Used for web application - this is the backend API server.
# This should be passed as a build-time variable (ARG) in docker.
PUBLIC_SERVER_URL=http://localhost:3035
PUBLIC_SERVER_API_PATH=/api

# Keep in sync with apps/server AUTH_MODE:
# - dev-password
# - sso-only
PUBLIC_AUTH_MODE=dev-password
# Set to true to hide deep research entry points in the web app.
# Keep in sync with apps/server and apps/worker DISABLE_DEEP_RESEARCH.
# PUBLIC_DISABLE_DEEP_RESEARCH=false

# Used only to set default port/host in development (vite.config.ts)
PUBLIC_WEB_URL=http://localhost:8085

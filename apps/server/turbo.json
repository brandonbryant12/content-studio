{
  "$schema": "https://turborepo.org/schema.json",
  "extends": ["//"],
  "tasks": {
    "dev": {
      "env": [
        "SERVER_*",
        "NODE_EXTRA_CA_CERTS",
        "PUBLIC_WEB_URL",
        "PUBLIC_SERVER_URL",
        "CORS_ORIGINS",
        "AUTH_COOKIE_SAME_SITE",
        "AUTH_COOKIE_SECURE"
      ],
      "inputs": ["$TURBO_DEFAULT$", ".env"],
      "persistent": true
    },
    "build": {
      "env": [
        "SERVER_*",
        "NODE_EXTRA_CA_CERTS",
        "PUBLIC_WEB_URL",
        "PUBLIC_SERVER_URL",
        "CORS_ORIGINS",
        "AUTH_COOKIE_SAME_SITE",
        "AUTH_COOKIE_SECURE"
      ],
      "inputs": ["$TURBO_DEFAULT$", ".env"]
    },
    "start": {
      "env": [
        "SERVER_*",
        "NODE_EXTRA_CA_CERTS",
        "PUBLIC_WEB_URL",
        "PUBLIC_SERVER_URL",
        "CORS_ORIGINS",
        "AUTH_COOKIE_SAME_SITE",
        "AUTH_COOKIE_SECURE"
      ],
      "persistent": true
    }
  }
}

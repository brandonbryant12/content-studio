SERVER_AUTH_SECRET=please_change_this_in_production

# Auth mode:
# - dev-password: email/password only (default local dev)
# - hybrid: Microsoft SSO + email/password
# - sso-only: Microsoft SSO only
AUTH_MODE=dev-password

# Microsoft SSO (required when AUTH_MODE=hybrid or sso-only)
# AUTH_MICROSOFT_CLIENT_ID=
# AUTH_MICROSOFT_CLIENT_SECRET=
# AUTH_MICROSOFT_TENANT_ID=
#
# Comma-separated Microsoft Graph group IDs used to assign app roles.
# Users in an admin group receive role=admin; users in a user group receive role=user.
# AUTH_ROLE_ADMIN_GROUP_IDS=
# AUTH_ROLE_USER_GROUP_IDS=

SERVER_POSTGRES_URL=postgres://postgres:postgres@localhost:5432/postgres
SERVER_REDIS_URL=redis://localhost:6379
SSE_REDIS_CHANNEL_PREFIX=cs:sse:user
SERVER_HOST=localhost
SERVER_PORT=3035

# Backend URL, used to configure OpenAPI (Scalar)
PUBLIC_SERVER_URL=http://localhost:3035
PUBLIC_SERVER_API_PATH=/api

# Frontend URL, used to configure trusted origin (cors)
PUBLIC_WEB_URL=http://localhost:8085

# AI Configuration
# Use mock AI services for LLM and TTS (set to false to use real AI)
# Defaults to true in development, false in production
USE_MOCK_AI=true

# AI Provider: 'gemini' or 'vertex' (only needed when USE_MOCK_AI=false)
# AI_PROVIDER=gemini
# GEMINI_API_KEY=your-api-key-here

# Telemetry (Datadog / OTLP)
# Enabled by default in production (NODE_ENV=production)
# TELEMETRY_ENABLED=true
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces
# OTEL_EXPORTER_OTLP_HEADERS=DD-API-KEY=your-datadog-api-key
# OTEL_SERVICE_NAME=content-studio-server
# OTEL_SERVICE_VERSION=0.0.0
# OTEL_ENV=production

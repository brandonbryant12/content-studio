{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["version", "coreWorkflows", "utilitySkills"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "coreWorkflows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/coreWorkflow"
      }
    },
    "utilitySkills": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/utilitySkill"
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$"
    },
    "lane": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$"
    },
    "skill": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$"
    },
    "docsPath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^agent-engine/workflows/[a-z0-9-]+/README\\.md$"
    },
    "coreWorkflow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "memoryKey",
        "summary",
        "primarySkills",
        "automationLanes",
        "docsPath"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "memoryKey": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "primarySkills": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/skill"
          }
        },
        "automationLanes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/lane"
          }
        },
        "docsPath": {
          "$ref": "#/$defs/docsPath"
        }
      }
    },
    "utilitySkill": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "memoryKey",
        "summary",
        "skills",
        "usedWithWorkflows",
        "automationLanes",
        "docsPath"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "memoryKey": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "skills": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/skill"
          }
        },
        "usedWithWorkflows": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "automationLanes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/lane"
          }
        },
        "docsPath": {
          "$ref": "#/$defs/docsPath"
        }
      }
    }
  }
}

#!/usr/bin/env bash
set -euo pipefail

ENV_FILE=".env.deploy"

error() { printf "\033[0;31m✗\033[0m %s\n" "$1" >&2; }
info() { printf "\033[0;32m✓\033[0m %s\n" "$1"; }

if ! command -v git >/dev/null 2>&1; then
  error "git is required but not installed."
  exit 1
fi

if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  error "Run this command inside the repository."
  exit 1
fi

if ! git diff --quiet || ! git diff --cached --quiet; then
  error "Working tree has local changes. Commit/stash them before running ./redeploy."
  exit 1
fi

info "Pulling latest changes (fast-forward only)..."
git pull --ff-only

if [[ -f "$ENV_FILE" ]]; then
  info "Re-deploying with existing $ENV_FILE"
  printf 'y\n' | ./deploy
else
  info "$ENV_FILE not found; launching interactive deploy setup"
  ./deploy
fi

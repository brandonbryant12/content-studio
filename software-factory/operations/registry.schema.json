{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "software-factory.operations.registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "operations"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "operations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "name",
          "description",
          "defaultModel",
          "defaultThinking",
          "strategy",
          "args",
          "runner"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "defaultModel": {
            "type": "string",
            "minLength": 1
          },
          "defaultThinking": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high",
              "xhigh"
            ]
          },
          "strategy": {
            "type": "string",
            "minLength": 1
          },
          "args": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "name",
                "type",
                "required",
                "description"
              ],
              "properties": {
                "name": {
                  "type": "string",
                  "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
                },
                "type": {
                  "type": "string",
                  "enum": [
                    "string",
                    "number",
                    "boolean"
                  ]
                },
                "required": {
                  "type": "boolean"
                },
                "description": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          },
          "labelingContext": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "modelLabels": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "thinkingLabels": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "decisionLabels": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          },
          "runner": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "type",
              "playbookPath"
            ],
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "ready-for-dev-router",
                  "codex-playbook"
                ]
              },
              "playbookPath": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    }
  }
}

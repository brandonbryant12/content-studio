# ── Update compose to use env-driven ports ───────────────────────────────────

build_and_run() {
  header "Deploying Content Studio"

  printf "  ${DIM}Services: web, server, worker, db, redis, minio${RESET}\n"
  printf "  ${DIM}Storage:  MinIO (S3-compatible object store)${RESET}\n"
  printf "  ${DIM}This will build images and start all containers.${RESET}\n\n"

  # Export vars so compose can interpolate them
  set -a
  # shellcheck disable=SC1090
  source "$ENV_FILE"
  set +a
  PROXY_ENV_UPDATED="false"
  NO_PROXY_UPDATED="false"
  ensure_internal_service_credentials

  DEPLOY_NODE_ENV="${DEPLOY_NODE_ENV:-development}"
  COMPOSE_PROJECT_NAME="${COMPOSE_PROJECT_NAME:-content-studio-deploy}"
  PUBLIC_URL_SCHEME="${PUBLIC_URL_SCHEME:-http}"
  TRUST_PROXY="${TRUST_PROXY:-false}"
  WEB_BIND_IP="${WEB_BIND_IP:-0.0.0.0}"
  SERVER_BIND_IP="${SERVER_BIND_IP:-0.0.0.0}"
  POSTGRES_BIND_IP="${POSTGRES_BIND_IP:-127.0.0.1}"
  REDIS_BIND_IP="${REDIS_BIND_IP:-127.0.0.1}"

  normalize_host_ip
  ensure_public_urls
  normalize_cors_origins
  normalize_no_proxy
  validate_runtime_constraints
  prepare_proxy_certificate

  if [[ "$INTERNAL_SERVICE_ENV_UPDATED" == "true" || "$NO_PROXY_UPDATED" == "true" || "$PROXY_ENV_UPDATED" == "true" ]]; then
    warn "Updating $ENV_FILE with normalized deploy defaults."
    write_env_file
  fi

  local deploy_log
  deploy_log="$(mktemp)"

  if ! compose --env-file "$ENV_FILE" up --build -d 2>&1 | tee "$deploy_log"; then
    if grep -q 'Could not resolve "../hooks/use-optimistic-create"' "$deploy_log"; then
      warn "Detected stale web build context. Retrying web build without Docker cache."
      if ! compose --env-file "$ENV_FILE" build --no-cache web; then
        error "Web rebuild still failed. Pull latest code and verify podcast list imports use-create-podcast."
        rm -f "$deploy_log"
        exit 1
      fi

      compose --env-file "$ENV_FILE" up -d
    else
      error "$COMPOSE_INVOCATION up --build failed. See logs above."
      print_failed_service_logs
      rm -f "$deploy_log"
      exit 1
    fi
  fi

  rm -f "$deploy_log"

  header "Waiting for Services"

  # Wait for health checks (up to 120s)
  local timeout=120
  local elapsed=0
  local interval=5

  while (( elapsed < timeout )); do
    local ready=0
    local total=0

    while IFS= read -r line; do
      total=$((total + 1))
      if echo "$line" | grep -q "(healthy)"; then
        ready=$((ready + 1))
      elif echo "$line" | grep -q "(unhealthy)"; then
        :
      elif echo "$line" | grep -q "(health: starting)"; then
        :
      elif echo "$line" | grep -q "(Up"; then
        ready=$((ready + 1))
      fi
    done < <(compose --env-file "$ENV_FILE" ps --format "{{.Name}} ({{.Status}})" 2>/dev/null | grep -v "minio-init")

    printf "\r  Ready: ${GREEN}%d${RESET}/%d services (${DIM}%ds elapsed${RESET})  " "$ready" "$total" "$elapsed"

    if (( ready >= total && total > 0 )); then
      echo
      break
    fi

    sleep "$interval"
    elapsed=$((elapsed + interval))
  done

  if (( elapsed >= timeout )); then
    echo
    warn "Some services may not be healthy yet. Check with: $COMPOSE_INVOCATION --env-file $ENV_FILE ps"
    print_failed_service_logs
  fi

  # ── Summary ────────────────────────────────────────────────────────────────
  header "Deploy Complete"

  printf "  ${GREEN}Mode${RESET}           %s\n" "$DEPLOY_NODE_ENV"
  printf "  ${GREEN}Project${RESET}        %s\n" "$COMPOSE_PROJECT_NAME"
  printf "  ${GREEN}Public Web${RESET}     %s\n" "$PUBLIC_WEB_URL"
  printf "  ${GREEN}Public API${RESET}     %s\n" "$PUBLIC_SERVER_URL"
  printf "  ${GREEN}Web Bind${RESET}       %s:%s -> 8080\n" "$WEB_BIND_IP" "$WEB_PORT"
  printf "  ${GREEN}API Bind${RESET}       %s:%s -> 3036\n" "$SERVER_BIND_IP" "$SERVER_PORT"
  printf "  ${GREEN}Compose Env${RESET}    %s ${DIM}(includes internal DB/MinIO creds)${RESET}\n" "$ENV_FILE"
  printf "  ${GREEN}MinIO Console${RESET}  http://%s:%s\n" "$HOST_IP" "$MINIO_UI_PORT"
  printf "  ${GREEN}MinIO S3 API${RESET}   http://%s:%s\n" "$HOST_IP" "$MINIO_API_PORT"
  printf "  ${GREEN}PostgreSQL${RESET}     %s:%s\n" "$POSTGRES_BIND_IP" "$POSTGRES_PORT"
  printf "  ${GREEN}Redis${RESET}          %s:%s\n" "$REDIS_BIND_IP" "$REDIS_PORT"

  printf "\n  ${DIM}Useful commands:${RESET}\n"
  printf "    %s --env-file %s logs -f        ${DIM}# tail all logs${RESET}\n" "$COMPOSE_INVOCATION" "$ENV_FILE"
  printf "    %s --env-file %s logs -f server  ${DIM}# tail server logs${RESET}\n" "$COMPOSE_INVOCATION" "$ENV_FILE"
  printf "    %s --env-file %s down            ${DIM}# stop everything${RESET}\n" "$COMPOSE_INVOCATION" "$ENV_FILE"
  printf "    %s --env-file %s down -v         ${DIM}# stop + delete volumes${RESET}\n" "$COMPOSE_INVOCATION" "$ENV_FILE"
  printf "    ./deploy                                     ${DIM}# re-deploy (reuses config)${RESET}\n"
  printf "    ./redeploy                                   ${DIM}# git pull --ff-only + re-deploy${RESET}\n"
  printf "    pnpm deploy:linux                            ${DIM}# same as ./deploy${RESET}\n"
  printf "    pnpm redeploy:linux                          ${DIM}# same as ./redeploy${RESET}\n"
}

# ── Main ─────────────────────────────────────────────────────────────────────

main() {
  printf "\n${BOLD}${CYAN}"
  printf "  ┌─────────────────────────────────────────┐\n"
  printf "  │       Content Studio — Deploy            │\n"
  printf "  │  Docker Compose interactive setup        │\n"
  printf "  └─────────────────────────────────────────┘\n"
  printf "${RESET}\n"

  choose_sudo_mode
  check_prerequisites

  if ! load_existing_env; then
    load_app_defaults
    collect_variables
    write_env_file
  else
    # Load existing values for the summary
    set -a
    # shellcheck disable=SC1090
    source "$ENV_FILE"
    set +a
    ensure_internal_service_credentials
    if [[ "$INTERNAL_SERVICE_ENV_UPDATED" == "true" ]]; then
      warn "Updating $ENV_FILE with internal Compose credential defaults."
      write_env_file
    fi
  fi

  build_and_run
}

main "$@"

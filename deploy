#!/usr/bin/env bash
set -euo pipefail

# ─────────────────────────────────────────────────────────────────────────────
# Content Studio — Interactive Deploy Script
#
# Prompts for all required environment variables, deduplicates across services,
# writes a root .env for sudo docker-compose, then builds and starts everything.
# ─────────────────────────────────────────────────────────────────────────────

ENV_FILE=".env.deploy"

# ── Colors ───────────────────────────────────────────────────────────────────
BOLD='\033[1m'
DIM='\033[2m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
RED='\033[0;31m'
RESET='\033[0m'

header()  { printf "\n${BOLD}${CYAN}═══ %s ═══${RESET}\n\n" "$1"; }
info()    { printf "${GREEN}✓${RESET} %s\n" "$1"; }
warn()    { printf "${YELLOW}⚠${RESET} %s\n" "$1"; }
error()   { printf "${RED}✗${RESET} %s\n" "$1" >&2; }

# ── Env-file reader ────────────────────────────────────────────────────────

# read_env_value FILE KEY — returns last non-commented value for KEY, or ""
read_env_value() {
  local file="$1" key="$2"
  [[ -f "$file" ]] || return 0
  grep -E "^${key}=" "$file" 2>/dev/null | tail -1 | sed "s/^${key}=//" | sed 's/^["'"'"']//;s/["'"'"']$//'
}

# extract_port "http://host:1234" → "1234"
extract_port() {
  echo "$1" | sed -nE 's|.*:([0-9]+)/?$|\1|p'
}

extract_scheme() {
  echo "$1" | sed -nE 's|^([a-zA-Z][a-zA-Z0-9+.-]*)://.*$|\1|p'
}

build_url() {
  local scheme="$1" host="$2" port="$3"
  echo "${scheme}://${host}:${port}"
}

build_web_origin() {
  local scheme="${PUBLIC_URL_SCHEME:-http}"
  local host_ip="${HOST_IP:-localhost}"
  local web_port="${WEB_PORT:-8086}"
  build_url "$scheme" "$host_ip" "$web_port"
}

build_server_origin() {
  local scheme="${PUBLIC_URL_SCHEME:-http}"
  local host_ip="${HOST_IP:-localhost}"
  local server_port="${SERVER_PORT:-3036}"
  build_url "$scheme" "$host_ip" "$server_port"
}

refresh_public_urls() {
  PUBLIC_WEB_URL="$(build_web_origin)"
  PUBLIC_SERVER_URL="$(build_server_origin)"
}

normalize_host_ip() {
  [[ -n "${HOST_IP:-}" ]] || return 0

  if [[ "$HOST_IP" =~ ^https?:// ]]; then
    warn "Host should not include protocol. Stripping scheme from HOST_IP."
    HOST_IP="${HOST_IP#http://}"
    HOST_IP="${HOST_IP#https://}"
  fi

  HOST_IP="${HOST_IP%%/*}"
  HOST_IP="${HOST_IP%/}"

  if [[ -z "$HOST_IP" ]]; then
    warn "HOST_IP resolved to empty value. Falling back to localhost."
    HOST_IP="localhost"
  fi
}

normalize_cors_origins() {
  local web_origin
  web_origin="$(build_web_origin)"
  local normalized_origins=""
  local has_web_origin="false"

  if [[ -z "${CORS_ORIGINS:-}" || -z "${CORS_ORIGINS//[[:space:]]/}" ]]; then
    warn "CORS_ORIGINS is empty. Using ${web_origin}."
    CORS_ORIGINS="$web_origin"
    return
  fi

  if [[ "$CORS_ORIGINS" == "*" ]]; then
    warn "CORS_ORIGINS='*' is not allowed in this deploy flow. Using ${web_origin}."
    CORS_ORIGINS="$web_origin"
    return
  fi

  IFS=',' read -r -a _cors_parts <<< "$CORS_ORIGINS"
  for origin in "${_cors_parts[@]}"; do
    # trim leading/trailing whitespace
    origin="${origin#"${origin%%[![:space:]]*}"}"
    origin="${origin%"${origin##*[![:space:]]}"}"
    [[ -z "$origin" ]] && continue

    [[ "$origin" == "$web_origin" ]] && has_web_origin="true"

    if [[ ",${normalized_origins}," != *",${origin},"* ]]; then
      normalized_origins="${normalized_origins:+${normalized_origins},}${origin}"
    fi
  done

  if [[ -z "$normalized_origins" ]]; then
    normalized_origins="$web_origin"
    has_web_origin="true"
  fi

  if [[ "$has_web_origin" != "true" ]]; then
    warn "Adding web origin to CORS_ORIGINS: ${web_origin}"
    normalized_origins="${normalized_origins},${web_origin}"
  fi

  CORS_ORIGINS="$normalized_origins"
}

validate_runtime_constraints() {
  if [[ -n "${HTTPS_PROXY:-}" || -n "${HTTP_PROXY:-}" ]]; then
    if [[ -z "${NODE_EXTRA_CA_CERTS:-}" ]]; then
      error "NODE_EXTRA_CA_CERTS is required when HTTPS_PROXY or HTTP_PROXY is configured."
      exit 1
    fi
  fi

  if [[ "${DEPLOY_NODE_ENV:-development}" == "production" ]]; then
    if [[ "${PUBLIC_URL_SCHEME:-http}" != "https" ]]; then
      error "PUBLIC_URL_SCHEME must be https when DEPLOY_NODE_ENV=production."
      exit 1
    fi

    if [[ "${AUTH_MODE:-dev-password}" == "dev-password" ]]; then
      error "AUTH_MODE=dev-password is not allowed when DEPLOY_NODE_ENV=production."
      exit 1
    fi

    if [[ "${TRUST_PROXY:-false}" != "true" ]]; then
      error "TRUST_PROXY must be true when DEPLOY_NODE_ENV=production."
      exit 1
    fi
  fi
}

print_failed_service_logs() {
  local failed_services
  failed_services=$(
    sudo docker-compose --env-file "$ENV_FILE" ps --status exited --services 2>/dev/null \
      | grep -vE '^(migrate|minio-init)$' || true
  )
  [[ -n "$failed_services" ]] || return 0

  warn "Some services exited during startup. Showing recent logs:"
  while IFS= read -r service; do
    [[ -z "$service" ]] && continue
    printf "\n${BOLD}${YELLOW}--- %s (last 80 lines) ---${RESET}\n" "$service"
    sudo docker-compose --env-file "$ENV_FILE" logs --no-color --tail=80 "$service" || true
  done <<< "$failed_services"
}

# ── Load defaults from existing app .env files ─────────────────────────────

load_app_defaults() {
  local server_env="apps/server/.env"
  local web_env="apps/web/.env"
  local worker_env="apps/worker/.env"

  local found_files=""
  for f in "$server_env" "$web_env" "$worker_env"; do
    [[ -f "$f" ]] && found_files="$found_files $f"
  done

  if [[ -n "$found_files" ]]; then
    info "Found existing .env files:${found_files}"
    printf "  ${DIM}Values from these files will be suggested as defaults.${RESET}\n"
  fi

  # ── Auth (prefer server) ──────────────────────────────────────────────
  _DEF_SERVER_AUTH_SECRET=$(read_env_value "$server_env" "SERVER_AUTH_SECRET")
  _DEF_AUTH_MODE=$(read_env_value "$server_env" "AUTH_MODE")
  # Fall back to web's PUBLIC_AUTH_MODE
  [[ -z "$_DEF_AUTH_MODE" ]] && _DEF_AUTH_MODE=$(read_env_value "$web_env" "PUBLIC_AUTH_MODE")

  _DEF_DEPLOY_NODE_ENV=$(read_env_value "$server_env" "NODE_ENV")
  [[ -z "$_DEF_DEPLOY_NODE_ENV" ]] && _DEF_DEPLOY_NODE_ENV=$(read_env_value "$worker_env" "NODE_ENV")
  _DEF_TRUST_PROXY=$(read_env_value "$server_env" "TRUST_PROXY")

  _DEF_AUTH_MICROSOFT_CLIENT_ID=$(read_env_value "$server_env" "AUTH_MICROSOFT_CLIENT_ID")
  _DEF_AUTH_MICROSOFT_CLIENT_SECRET=$(read_env_value "$server_env" "AUTH_MICROSOFT_CLIENT_SECRET")
  _DEF_AUTH_MICROSOFT_TENANT_ID=$(read_env_value "$server_env" "AUTH_MICROSOFT_TENANT_ID")
  _DEF_AUTH_ROLE_ADMIN_GROUP_IDS=$(read_env_value "$server_env" "AUTH_ROLE_ADMIN_GROUP_IDS")
  _DEF_AUTH_ROLE_USER_GROUP_IDS=$(read_env_value "$server_env" "AUTH_ROLE_USER_GROUP_IDS")

  # ── AI (prefer server, fall back to worker) ───────────────────────────
  _DEF_USE_MOCK_AI=$(read_env_value "$server_env" "USE_MOCK_AI")
  [[ -z "$_DEF_USE_MOCK_AI" ]] && _DEF_USE_MOCK_AI=$(read_env_value "$worker_env" "USE_MOCK_AI")

  _DEF_GEMINI_API_KEY=$(read_env_value "$server_env" "GEMINI_API_KEY")
  [[ -z "$_DEF_GEMINI_API_KEY" ]] && _DEF_GEMINI_API_KEY=$(read_env_value "$worker_env" "GEMINI_API_KEY")

  # ── CORS ──────────────────────────────────────────────────────────────
  _DEF_CORS_ORIGINS=$(read_env_value "$server_env" "CORS_ORIGINS")

  # ── Telemetry (prefer server, fall back to worker) ────────────────────
  _DEF_TELEMETRY_ENABLED=$(read_env_value "$server_env" "TELEMETRY_ENABLED")
  [[ -z "$_DEF_TELEMETRY_ENABLED" ]] && _DEF_TELEMETRY_ENABLED=$(read_env_value "$worker_env" "TELEMETRY_ENABLED")

  _DEF_OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=$(read_env_value "$server_env" "OTEL_EXPORTER_OTLP_TRACES_ENDPOINT")
  [[ -z "$_DEF_OTEL_EXPORTER_OTLP_TRACES_ENDPOINT" ]] && \
    _DEF_OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=$(read_env_value "$worker_env" "OTEL_EXPORTER_OTLP_TRACES_ENDPOINT")

  _DEF_OTEL_EXPORTER_OTLP_HEADERS=$(read_env_value "$server_env" "OTEL_EXPORTER_OTLP_HEADERS")
  [[ -z "$_DEF_OTEL_EXPORTER_OTLP_HEADERS" ]] && \
    _DEF_OTEL_EXPORTER_OTLP_HEADERS=$(read_env_value "$worker_env" "OTEL_EXPORTER_OTLP_HEADERS")

  # ── Proxy (prefer server, fall back to worker) ──────────────────────────
  _DEF_HTTPS_PROXY=$(read_env_value "$server_env" "HTTPS_PROXY")
  [[ -z "$_DEF_HTTPS_PROXY" ]] && _DEF_HTTPS_PROXY=$(read_env_value "$worker_env" "HTTPS_PROXY")
  _DEF_HTTP_PROXY=$(read_env_value "$server_env" "HTTP_PROXY")
  [[ -z "$_DEF_HTTP_PROXY" ]] && _DEF_HTTP_PROXY=$(read_env_value "$worker_env" "HTTP_PROXY")
  _DEF_NO_PROXY=$(read_env_value "$server_env" "NO_PROXY")
  [[ -z "$_DEF_NO_PROXY" ]] && _DEF_NO_PROXY=$(read_env_value "$worker_env" "NO_PROXY")
  _DEF_NODE_EXTRA_CA_CERTS=$(read_env_value "$server_env" "NODE_EXTRA_CA_CERTS")
  [[ -z "$_DEF_NODE_EXTRA_CA_CERTS" ]] && _DEF_NODE_EXTRA_CA_CERTS=$(read_env_value "$worker_env" "NODE_EXTRA_CA_CERTS")

  # ── Ports (extract from URLs or explicit vars) ────────────────────────
  _DEF_SERVER_PORT=$(read_env_value "$server_env" "SERVER_PORT")
  if [[ -z "$_DEF_SERVER_PORT" ]]; then
    local server_url
    server_url=$(read_env_value "$server_env" "PUBLIC_SERVER_URL")
    [[ -n "$server_url" ]] && _DEF_SERVER_PORT=$(extract_port "$server_url")
  fi

  _DEF_WEB_PORT=""
  local web_url
  web_url=$(read_env_value "$server_env" "PUBLIC_WEB_URL")
  [[ -z "$web_url" ]] && web_url=$(read_env_value "$web_env" "PUBLIC_WEB_URL")
  [[ -n "$web_url" ]] && _DEF_WEB_PORT=$(extract_port "$web_url")

  _DEF_PUBLIC_URL_SCHEME=""
  if [[ -n "$web_url" ]]; then
    _DEF_PUBLIC_URL_SCHEME=$(extract_scheme "$web_url")
  fi
  if [[ -z "$_DEF_PUBLIC_URL_SCHEME" ]]; then
    local server_public_url
    server_public_url=$(read_env_value "$server_env" "PUBLIC_SERVER_URL")
    [[ -n "$server_public_url" ]] && _DEF_PUBLIC_URL_SCHEME=$(extract_scheme "$server_public_url")
  fi

  local existing_env="$ENV_FILE"

  [[ -z "$_DEF_DEPLOY_NODE_ENV" ]] && _DEF_DEPLOY_NODE_ENV=$(read_env_value "$existing_env" "DEPLOY_NODE_ENV")
  [[ -z "$_DEF_TRUST_PROXY" ]] && _DEF_TRUST_PROXY=$(read_env_value "$existing_env" "TRUST_PROXY")
  [[ -z "$_DEF_PUBLIC_URL_SCHEME" ]] && _DEF_PUBLIC_URL_SCHEME=$(read_env_value "$existing_env" "PUBLIC_URL_SCHEME")
  [[ -z "$_DEF_CORS_ORIGINS" ]] && _DEF_CORS_ORIGINS=$(read_env_value "$existing_env" "CORS_ORIGINS")
  [[ -z "$_DEF_SERVER_PORT" ]] && _DEF_SERVER_PORT=$(read_env_value "$existing_env" "SERVER_PORT")
  [[ -z "$_DEF_WEB_PORT" ]] && _DEF_WEB_PORT=$(read_env_value "$existing_env" "WEB_PORT")
  [[ -z "$_DEF_HTTPS_PROXY" ]] && _DEF_HTTPS_PROXY=$(read_env_value "$existing_env" "HTTPS_PROXY")
  [[ -z "$_DEF_HTTP_PROXY" ]] && _DEF_HTTP_PROXY=$(read_env_value "$existing_env" "HTTP_PROXY")
  [[ -z "$_DEF_NO_PROXY" ]] && _DEF_NO_PROXY=$(read_env_value "$existing_env" "NO_PROXY")
  [[ -z "$_DEF_NODE_EXTRA_CA_CERTS" ]] && _DEF_NODE_EXTRA_CA_CERTS=$(read_env_value "$existing_env" "NODE_EXTRA_CA_CERTS")
  _DEF_POSTGRES_BIND_IP=$(read_env_value "$existing_env" "POSTGRES_BIND_IP")
  _DEF_REDIS_BIND_IP=$(read_env_value "$existing_env" "REDIS_BIND_IP")
}

# ── Prompt helpers ───────────────────────────────────────────────────────────

# prompt VAR_NAME "description" [default]
prompt() {
  local var_name="$1" desc="$2" default="${3:-}"
  local value
  if [[ -n "$default" ]]; then
    printf "  ${BOLD}%s${RESET} ${DIM}(%s)${RESET}\n" "$desc" "$var_name"
    printf "  Default: ${DIM}%s${RESET}\n" "$default"
    printf "  > "
    read -r value
    value="${value:-$default}"
  else
    printf "  ${BOLD}%s${RESET} ${DIM}(%s)${RESET}\n" "$desc" "$var_name"
    printf "  > "
    read -r value
  fi
  eval "$var_name=\$value"
}

# prompt_secret VAR_NAME "description" [default]
# Masks displayed default for secrets longer than 12 chars.
prompt_secret() {
  local var_name="$1" desc="$2" default="${3:-}"
  local value display_default
  if [[ -n "$default" ]]; then
    if (( ${#default} > 12 )); then
      display_default="${default:0:4}····${default: -4}"
    else
      display_default="$default"
    fi
    printf "  ${BOLD}%s${RESET} ${DIM}(%s)${RESET}\n" "$desc" "$var_name"
    printf "  Default: ${DIM}%s${RESET}\n" "$display_default"
    printf "  > "
    read -rs value
    echo
    value="${value:-$default}"
  else
    printf "  ${BOLD}%s${RESET} ${DIM}(%s)${RESET}\n" "$desc" "$var_name"
    printf "  > "
    read -rs value
    echo
  fi
  eval "$var_name=\$value"
}

# prompt_choice VAR_NAME "description" "opt1|opt2|opt3" [default]
prompt_choice() {
  local var_name="$1" desc="$2" options="$3" default="${4:-}"
  local value
  printf "  ${BOLD}%s${RESET} ${DIM}(%s)${RESET}\n" "$desc" "$var_name"
  printf "  Options: ${CYAN}%s${RESET}\n" "$options"
  if [[ -n "$default" ]]; then
    printf "  Default: ${DIM}%s${RESET}\n" "$default"
  fi
  while true; do
    printf "  > "
    read -r value
    value="${value:-$default}"
    if echo "$options" | tr '|' '\n' | grep -qx "$value"; then
      break
    fi
    warn "Invalid choice. Pick one of: $options"
  done
  eval "$var_name=\$value"
}

# prompt_yesno VAR_NAME "description" [default: y/n]
prompt_yesno() {
  local var_name="$1" desc="$2" default="${3:-y}"
  local value
  printf "  ${BOLD}%s${RESET} [y/n] ${DIM}(default: %s)${RESET}: " "$desc" "$default"
  read -r value
  value="${value:-$default}"
  case "$value" in
    [Yy]*) eval "$var_name=true" ;;
    *)     eval "$var_name=false" ;;
  esac
}

# ── Prerequisites ────────────────────────────────────────────────────────────

check_prerequisites() {
  header "Checking Prerequisites"

  if ! command -v sudo &>/dev/null; then
    error "sudo is required but not installed."
    exit 1
  fi
  info "sudo found"

  if ! command -v docker &>/dev/null; then
    error "Docker is not installed. Please install Docker first."
    exit 1
  fi
  info "Docker found"

  if ! command -v docker-compose &>/dev/null; then
    error "docker-compose is not installed. Please install docker-compose first."
    exit 1
  fi

  if ! sudo docker-compose version &>/dev/null; then
    error "docker-compose found, but sudo docker-compose failed. Verify sudo permissions."
    exit 1
  fi
  info "Docker Compose found"

  if ! sudo docker info &>/dev/null 2>&1; then
    error "Docker daemon is not running or not accessible via sudo."
    exit 1
  fi
  info "Docker daemon is running"
}

# ── Detect host IP ──────────────────────────────────────────────────────────

detect_host_ip() {
  local ip=""
  case "$(uname -s)" in
    Darwin)
      ip=$(ipconfig getifaddr en0 2>/dev/null || true)
      ;;
    Linux)
      ip=$(hostname -I 2>/dev/null | awk '{print $1}' || true)
      ;;
  esac
  echo "${ip:-localhost}"
}

# ── Generate auth secret ────────────────────────────────────────────────────

generate_secret() {
  openssl rand -base64 32 2>/dev/null || head -c 32 /dev/urandom | base64
}

# ── Load existing env ────────────────────────────────────────────────────────

load_existing_env() {
  if [[ -f "$ENV_FILE" ]]; then
    warn "Found existing $ENV_FILE"
    prompt_yesno REUSE_ENV "Use existing configuration?" "y"
    if [[ "$REUSE_ENV" == "true" ]]; then
      info "Using existing $ENV_FILE"
      return 0
    fi
  fi
  return 1
}

# ── Collect all variables ───────────────────────────────────────────────────

collect_variables() {
  local detected_ip
  detected_ip=$(detect_host_ip)

  # ── Docker Registry ──────────────────────────────────────────────────────
  header "Docker Registry"
  printf "  ${DIM}Registry used to pull base images (postgres, redis, minio).${RESET}\n"
  printf "  ${DIM}Examples: docker.io, ghcr.io, registry.example.com${RESET}\n\n"

  prompt DOCKER_REGISTRY "Docker image registry" "docker.io"

  # ── Network ──────────────────────────────────────────────────────────────
  header "Network Configuration"
  printf "  ${DIM}All services use this IP for public-facing URLs.${RESET}\n"
  printf "  ${DIM}Use host/IP only (no protocol). Example: localhost, 10.0.0.25, studio.example.com${RESET}\n\n"

  prompt HOST_IP "Host IP / hostname" "$detected_ip"
  normalize_host_ip

  # ── Runtime ──────────────────────────────────────────────────────────────
  header "Runtime Mode"
  printf "  ${DIM}development: easiest fresh-VM setup (HTTP + dev-password allowed).${RESET}\n"
  printf "  ${DIM}production: enforces HTTPS + SSO auth + trusted proxy settings.${RESET}\n\n"

  local node_env_default="${_DEF_DEPLOY_NODE_ENV:-development}"
  if [[ "$node_env_default" != "development" && "$node_env_default" != "production" ]]; then
    node_env_default="development"
  fi
  prompt_choice DEPLOY_NODE_ENV "Deployment runtime mode" "development|production" "$node_env_default"

  local scheme_default="${_DEF_PUBLIC_URL_SCHEME:-}"
  if [[ -z "$scheme_default" ]]; then
    if [[ "$DEPLOY_NODE_ENV" == "production" ]]; then
      scheme_default="https"
    else
      scheme_default="http"
    fi
  fi
  prompt_choice PUBLIC_URL_SCHEME "Public URL scheme" "http|https" "$scheme_default"
  if [[ "$DEPLOY_NODE_ENV" == "production" && "$PUBLIC_URL_SCHEME" != "https" ]]; then
    warn "For production mode, forcing PUBLIC_URL_SCHEME=https."
    PUBLIC_URL_SCHEME="https"
  fi

  local trust_proxy_default="n"
  if [[ "$DEPLOY_NODE_ENV" == "production" || "${_DEF_TRUST_PROXY:-}" == "true" ]]; then
    trust_proxy_default="y"
  fi
  prompt_yesno TRUST_PROXY "Trust x-forwarded-* headers from ingress/reverse proxy?" "$trust_proxy_default"

  # ── Authentication ───────────────────────────────────────────────────────
  header "Authentication"

  local default_secret
  default_secret="${_DEF_SERVER_AUTH_SECRET:-$(generate_secret)}"
  prompt_secret SERVER_AUTH_SECRET "Auth session signing secret" "$default_secret"

  local auth_options="dev-password|hybrid|sso-only"
  local auth_default="${_DEF_AUTH_MODE:-dev-password}"
  if [[ "$DEPLOY_NODE_ENV" == "production" ]]; then
    auth_options="hybrid|sso-only"
    if [[ "$auth_default" == "dev-password" ]]; then
      auth_default="hybrid"
    fi
  fi
  prompt_choice AUTH_MODE "Authentication mode" "$auth_options" "$auth_default"

  AUTH_MICROSOFT_CLIENT_ID=""
  AUTH_MICROSOFT_CLIENT_SECRET=""
  AUTH_MICROSOFT_TENANT_ID=""
  AUTH_ROLE_ADMIN_GROUP_IDS=""
  AUTH_ROLE_USER_GROUP_IDS=""

  if [[ "$AUTH_MODE" != "dev-password" ]]; then
    printf "\n  ${DIM}Microsoft SSO configuration required for '%s' mode${RESET}\n\n" "$AUTH_MODE"
    prompt        AUTH_MICROSOFT_CLIENT_ID     "Microsoft OAuth client ID"            "${_DEF_AUTH_MICROSOFT_CLIENT_ID:-}"
    prompt_secret AUTH_MICROSOFT_CLIENT_SECRET "Microsoft OAuth client secret"        "${_DEF_AUTH_MICROSOFT_CLIENT_SECRET:-}"
    prompt        AUTH_MICROSOFT_TENANT_ID     "Microsoft tenant ID"                  "${_DEF_AUTH_MICROSOFT_TENANT_ID:-}"
    prompt        AUTH_ROLE_ADMIN_GROUP_IDS    "Admin group IDs (comma-separated)"    "${_DEF_AUTH_ROLE_ADMIN_GROUP_IDS:-}"
    prompt        AUTH_ROLE_USER_GROUP_IDS     "User group IDs (comma-separated)"     "${_DEF_AUTH_ROLE_USER_GROUP_IDS:-}"
  fi

  # ── AI Services ──────────────────────────────────────────────────────────
  header "AI Services"

  local mock_default="y"
  [[ "$_DEF_USE_MOCK_AI" == "false" ]] && mock_default="n"
  prompt_yesno USE_MOCK_AI "Use mock AI? (no real API calls)" "$mock_default"

  GEMINI_API_KEY=""
  if [[ "$USE_MOCK_AI" == "false" ]]; then
    printf "\n  ${DIM}Real AI requires a Gemini API key.${RESET}\n\n"
    prompt_secret GEMINI_API_KEY "Google Gemini API key" "${_DEF_GEMINI_API_KEY:-}"
    if [[ -z "$GEMINI_API_KEY" ]]; then
      warn "No API key provided — AI features will fail at runtime."
    fi
  fi

  # ── Telemetry ────────────────────────────────────────────────────────────
  header "Telemetry (OpenTelemetry / Datadog)"

  local telemetry_default="n"
  [[ "$_DEF_TELEMETRY_ENABLED" == "true" ]] && telemetry_default="y"
  prompt_yesno TELEMETRY_ENABLED "Enable OTLP trace export?" "$telemetry_default"

  OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=""
  OTEL_EXPORTER_OTLP_HEADERS=""

  if [[ "$TELEMETRY_ENABLED" == "true" ]]; then
    prompt OTEL_EXPORTER_OTLP_TRACES_ENDPOINT "OTLP traces endpoint" "${_DEF_OTEL_EXPORTER_OTLP_TRACES_ENDPOINT:-http://localhost:4318/v1/traces}"
    prompt OTEL_EXPORTER_OTLP_HEADERS "OTLP headers (KEY=value,KEY2=value2)" "${_DEF_OTEL_EXPORTER_OTLP_HEADERS:-}"
  fi

  # ── Outbound Proxy ───────────────────────────────────────────────────────
  header "Outbound Proxy (optional)"
  printf "  ${DIM}Set these if your VM must route outbound traffic through a proxy.${RESET}\n"
  printf "  ${DIM}If HTTPS_PROXY or HTTP_PROXY is set, NODE_EXTRA_CA_CERTS is required.${RESET}\n\n"

  local configure_proxy_default="n"
  if [[ -n "${_DEF_HTTPS_PROXY:-}" || -n "${_DEF_HTTP_PROXY:-}" || -n "${_DEF_NODE_EXTRA_CA_CERTS:-}" ]]; then
    configure_proxy_default="y"
  fi
  prompt_yesno CONFIGURE_PROXY "Configure outbound proxy variables?" "$configure_proxy_default"

  HTTPS_PROXY=""
  HTTP_PROXY=""
  NO_PROXY=""
  NODE_EXTRA_CA_CERTS=""
  if [[ "$CONFIGURE_PROXY" == "true" ]]; then
    prompt HTTPS_PROXY "HTTPS proxy URL (optional)" "${_DEF_HTTPS_PROXY:-}"
    prompt HTTP_PROXY "HTTP proxy URL (optional)" "${_DEF_HTTP_PROXY:-}"
    prompt NO_PROXY "NO_PROXY hosts (comma-separated, optional)" "${_DEF_NO_PROXY:-localhost,127.0.0.1,db,redis,minio}"
    prompt NODE_EXTRA_CA_CERTS "Path to CA bundle file" "${_DEF_NODE_EXTRA_CA_CERTS:-/etc/ssl/certs/ca-certificates.crt}"
  fi

  # ── Ports ────────────────────────────────────────────────────────────────
  header "Port Configuration"
  printf "  ${DIM}Change these if you have port conflicts.${RESET}\n\n"

  prompt WEB_PORT        "Web app port"         "${_DEF_WEB_PORT:-8086}"
  prompt SERVER_PORT     "API server port"      "${_DEF_SERVER_PORT:-3036}"
  prompt POSTGRES_PORT   "PostgreSQL port"      "5432"
  prompt POSTGRES_BIND_IP "PostgreSQL bind IP (127.0.0.1 local-only, 0.0.0.0 external)" "${_DEF_POSTGRES_BIND_IP:-127.0.0.1}"
  prompt REDIS_PORT      "Redis port"           "6379"
  prompt REDIS_BIND_IP   "Redis bind IP (127.0.0.1 local-only, 0.0.0.0 external)" "${_DEF_REDIS_BIND_IP:-127.0.0.1}"
  prompt MINIO_API_PORT  "MinIO S3 API port"    "9001"
  prompt MINIO_UI_PORT   "MinIO console port"   "9090"

  refresh_public_urls

  # ── CORS ─────────────────────────────────────────────────────────────────
  header "CORS"
  printf "  ${DIM}Comma-separated origins. '*' is not supported in this deploy mode.${RESET}\n"
  printf "  ${DIM}The web app origin is always allowed.${RESET}\n\n"

  local default_cors_origins="${_DEF_CORS_ORIGINS:-$PUBLIC_WEB_URL}"
  if [[ "$default_cors_origins" == "*" ]]; then
    default_cors_origins="$PUBLIC_WEB_URL"
  fi
  prompt CORS_ORIGINS "Allowed CORS origins" "$default_cors_origins"

  normalize_cors_origins
  validate_runtime_constraints
}


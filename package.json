{
  "name": "content-studio",
  "private": true,
  "type": "module",
  "scripts": {
    "auth:schema:generate": "turbo run auth:schema:generate",
    "postauth:schema:generate": "echo NOTE: you will also need to fix styles and db:push your new schema",
    "build": "turbo run build",
    "clean": "turbo run clean",
    "db:push": "turbo -F @repo/db push",
    "db:migrate": "turbo -F @repo/db migrate",
    "db:generate": "turbo -F @repo/db generate",
    "db:studio": "turbo -F @repo/db studio",
    "dev": "turbo watch dev --continue",
    "env:copy-example": "turbo run env:copy-example",
    "env:remove": "turbo run env:remove",
    "format": "turbo run format --continue -- --cache --cache-location .cache/.prettiercache",
    "format:fix": "pnpm format --write",
    "lint": "turbo run lint --continue -- --cache --cache-location .cache/.eslintcache --max-warnings=0",
    "lint:fix": "pnpm lint --fix",
    "postclean": "git clean -xdf .cache .turbo node_modules",
    "spec:generate": "pnpm --filter server exec tsx ../../agent-engine/scripts/spec/generate.ts",
    "spec:check": "pnpm spec:generate && test -z \"$(git status --porcelain -- docs/master-spec.md docs/spec/generated)\"",
    "start": "turbo run start",
    "test": "vitest run",
    "test:invariants": "vitest run packages/media/src/shared/__tests__/safety-invariants.test.ts packages/api/src/server/__tests__/effect-handler.invariants.test.ts packages/api/src/server/__tests__/error-assertions.invariants.test.ts packages/api/src/server/__tests__/chat-handler.invariants.test.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:coverage:api": "pnpm --filter @repo/api test:coverage",
    "test:coverage:api:activity": "pnpm --filter @repo/api test:coverage:activity",
    "test:integration": "turbo run test:integration",
    "test:live": "vitest run --testPathPattern=live",
    "test:live:llm": "vitest run packages/ai/src/__tests__/live/llm.live.test.ts",
    "test:live:llm:smoke": "pnpm --filter @repo/ai test:live:llm:smoke",
    "test:live:tts": "vitest run packages/ai/src/__tests__/live/tts.live.test.ts",
    "test:live:storage": "vitest run packages/storage/src/__tests__/live/s3.live.test.ts",
    "test:e2e": "pnpm --filter web test:e2e",
    "test:e2e:ui": "pnpm --filter web test:e2e:ui",
    "test:db:up": "docker compose -f docker-compose.test.yml up -d --force-recreate --wait",
    "test:db:down": "docker compose -f docker-compose.test.yml down",
    "db:push:test": "DB_POSTGRES_URL=postgresql://test:test@localhost:5433/content_studio_test pnpm --filter @repo/db env:run drizzle-kit push --force",
    "test:db:setup": "pnpm test:db:up && pnpm db:push:test",
    "e2e:seed": "pnpm --filter web e2e:seed",
    "skills:check": "node agent-engine/scripts/skills/check-quality.mjs",
    "skills:check:strict": "node agent-engine/scripts/skills/check-quality.mjs --strict",
    "workflows:generate": "node agent-engine/scripts/workflows/generate-readme.mjs",
    "workflow-memory:coverage": "node agent-engine/scripts/workflow-memory/check-coverage.mjs",
    "workflow-memory:coverage:strict": "node agent-engine/scripts/workflow-memory/check-coverage.mjs --strict",
    "scenario:validate": "node agent-engine/scripts/workflow-memory/replay-scenarios.mjs",
    "scenario:validate:strict": "node agent-engine/scripts/workflow-memory/replay-scenarios.mjs --strict",
    "typecheck": "turbo run typecheck",
    "cli": "pnpm --filter @repo/cli dev --",
    "ui-add": "turbo run ui-add -F @repo/ui --"
  },
  "packageManager": "pnpm@10.23.0",
  "devDependencies": {
    "@effect/language-service": "^0.64.0",
    "@vitest/coverage-v8": "catalog:",
    "turbo": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22.10.0"
  },
  "pnpm": {
    "overrides": {
      "@eslint/eslintrc>ajv": "6.12.6"
    }
  }
}

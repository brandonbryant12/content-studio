{
  "name": "content-studio",
  "private": true,
  "type": "module",
  "scripts": {
    "auth:schema:generate": "turbo run auth:schema:generate",
    "postauth:schema:generate": "echo NOTE: you will also need to fix styles and db:push your new schema",
    "build": "turbo run build",
    "clean": "turbo run clean",
    "db:push": "turbo -F @repo/db push",
    "db:migrate": "turbo -F @repo/db migrate",
    "db:generate": "turbo -F @repo/db generate",
    "db:studio": "turbo -F @repo/db studio",
    "dev": "turbo watch dev --continue",
    "env:copy-example": "turbo run env:copy-example",
    "env:remove": "turbo run env:remove",
    "format": "turbo run format --continue -- --cache --cache-location .cache/.prettiercache",
    "format:fix": "pnpm format --write",
    "lint": "pnpm scripts:lint && turbo run lint --continue -- --cache --cache-location .cache/.eslintcache --max-warnings=0",
    "lint:fix": "pnpm lint --fix",
    "postclean": "git clean -xdf .cache .turbo node_modules",
    "spec:generate": "pnpm software-factory spec generate",
    "spec:check": "pnpm spec:generate && test -z \"$(git status --porcelain -- docs/master-spec.md docs/spec/generated)\"",
    "start": "turbo run start",
    "test": "vitest run",
    "test:scripts": "vitest run --config software-factory/scripts/vitest.config.ts",
    "test:invariants": "vitest run packages/media/src/shared/__tests__/safety-invariants.test.ts packages/api/src/server/__tests__/effect-handler.invariants.test.ts packages/api/src/server/__tests__/error-assertions.invariants.test.ts packages/api/src/server/__tests__/chat-handler.invariants.test.ts packages/testing/src/__tests__/docs-invariants.test.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:coverage:api": "pnpm --filter @repo/api test:coverage",
    "test:coverage:api:activity": "pnpm --filter @repo/api test:coverage:activity",
    "test:integration": "turbo run test:integration",
    "test:live": "vitest run --testPathPattern=live",
    "test:live:llm": "vitest run packages/ai/src/__tests__/live/llm.live.test.ts",
    "test:live:llm:smoke": "pnpm --filter @repo/ai test:live:llm:smoke",
    "test:live:tts": "vitest run packages/ai/src/__tests__/live/tts.live.test.ts",
    "test:live:storage": "vitest run packages/storage/src/__tests__/live/s3.live.test.ts",
    "test:e2e": "pnpm --filter web test:e2e",
    "test:e2e:ui": "pnpm --filter web test:e2e:ui",
    "e2e:seed": "pnpm --filter web e2e:seed",
    "skills:check": "pnpm software-factory skills check",
    "skills:check:strict": "pnpm software-factory skills check --strict",
    "workflows:generate": "pnpm software-factory workflows generate",
    "workflow-memory:add-entry": "pnpm software-factory workflow-memory add-entry",
    "workflow-memory:preflight": "pnpm software-factory workflow-memory preflight",
    "workflow-memory:sync": "pnpm software-factory workflow-memory sync",
    "workflow-memory:retrieve": "pnpm software-factory workflow-memory retrieve",
    "workflow-memory:compact": "pnpm software-factory workflow-memory compact",
    "workflow-memory:coverage": "pnpm software-factory workflow-memory coverage",
    "workflow-memory:coverage:strict": "pnpm software-factory workflow-memory coverage --strict",
    "workflow-memory:validate-scenarios": "pnpm software-factory workflow-memory validate-scenarios",
    "workflow-memory:validate-scenarios:strict": "pnpm software-factory workflow-memory validate-scenarios --strict",
    "software-factory": "pnpm exec tsx software-factory/scripts/factory/software-factory.ts",
    "ready-for-dev": "pnpm software-factory trigger fire --trigger-id ready-for-dev-executor",
    "scripts:lint": "pnpm software-factory scripts lint",
    "typecheck": "turbo run typecheck",
    "cli": "pnpm --filter @repo/cli dev --",
    "ui-add": "turbo run ui-add -F @repo/ui --"
  },
  "packageManager": "pnpm@10.23.0",
  "devDependencies": {
    "@effect/cli": "catalog:",
    "@effect/language-service": "^0.64.0",
    "@effect/platform": "catalog:",
    "@effect/platform-node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "ajv": "catalog:",
    "effect": "3.19.19",
    "tsx": "catalog:",
    "turbo": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22.10.0"
  },
  "pnpm": {
    "overrides": {
      "@eslint/eslintrc>ajv": "6.12.6"
    }
  }
}
